# 本项目复用上层 f:\desktop\Poem\.env(load_dotenv 会自动向上找),
# 也可以复制本文件为 poem_agent/.env 单独管理。

# 必填:DeepSeek(解析/分镜/路由/改写)
DEEPSEEK_API_KEY=sk-你的key

# 选填:硅基流动(Kolors 文生图 + Qwen-VL 质检)
# 不填 = 降级模式:画面全部用水墨字卡,质检环模拟通过,链路照样能跑
# 注册:https://siliconflow.cn → API 密钥
SILICONFLOW_API_KEY=

# 预留(v2):图生视频,配了才会在 premium 路由真的走视频生成
KLING_API_KEY=
